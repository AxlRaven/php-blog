Options -Indexes

# Do NOT use "php_flag" here — on CGI/FPM hosts it causes HTTP 500 for all files in this folder.

<FilesMatch "\.(?i:php|phtml|php3|php4|php5|phar)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
  </IfModule>
</FilesMatch>
